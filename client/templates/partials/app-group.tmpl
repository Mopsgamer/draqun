<div id="app-content" class="group">
    <div id="chat-view">
        <main id="chat">
            <div
                class="load-scroll"
                hx-trigger="intersect once"
                hx-swap="outerHTML"
                hx-get="/groups/{{.Group.Id}}/messages/page/1"
            >
            </div>
        </main>
        {{- template "partials/chat-input" .}}
    </div>
    <div id="members-view" class="secondary-view">
        <div class="secondary-view-header" slot="label">
            Members - {{.Group.MembersCount}}
        </div>
        <div id="members">
            <div
                class="load-scroll"
                hx-trigger="intersect once"
                hx-swap="outerHTML"
                hx-get="/groups/{{.Group.Id}}/members/page/1"
            >
            </div>
        </div>
    </div>
    <div id="search-view" class="secondary-view">
        <div class="secondary-view-header" slot="label">
            Search Results
        </div>
        <div id="search-results">
            <div class="secondary-view-empty">
                Type in the search box to find messages.
            </div>
        </div>
    </div>
    <div
        id="ws-chat"
        class="collapse"
        hx-ext="ws"
        ws-connect="/groups/ws/{{.Group.Id}}"
        hx-trigger="every 1.6s"
        ws-send=""
    >
    </div>
</div>
