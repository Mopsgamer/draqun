{
	"name": "@m234/draqun",
	"version": "0.0.0",
	"publish": false,
	"nodeModulesDir": "auto",
	"minimumDependencyAge": {
		"exclude": ["jsr:@m234/logger"],
		"age": "P7D"
	},
	"tasks": {
		"init": "deno run -A scripts/init.ts",
		"dev": "deno run -A scripts/dev.ts",
		"prod": "deno run -A scripts/prod.ts",
		"prepare": "deno lint & deno fmt & deno check",
		"front": "deno run -A scripts/make-front.ts",
		"back": "deno run -A scripts/make-back.ts",
		"back:cross": "deno run -A scripts/make-back-cross.ts",
		"release": "deno run -A scripts/release.ts"
	},
	"imports": {
		"@deno/esbuild-plugin": "jsr:@deno/esbuild-plugin@^1.2.1",
		"@m234/logger": "jsr:@m234/logger@^3.0.6",
		"@octokit/rest": "npm:@octokit/rest@^22.0.1",
		"@shoelace-style/shoelace": "npm:@shoelace-style/shoelace@^2.20.1",
		"@std/fmt": "jsr:@std/fmt@^1.0.10",
		"@std/fs": "jsr:@std/fs@^1.0.24",
		"@std/path": "jsr:@std/path@^1.1.6",
		"@tailwindcss/postcss": "npm:@tailwindcss/postcss@^4.3.2",
		"@types/semver": "npm:@types/semver@^7.7.1",
		"@types/swagger-ui-dist": "npm:@types/swagger-ui-dist@^3.30.6",
		"dotenv": "npm:dotenv@^17.4.2",
		"esbuild": "npm:esbuild@^0.28.1",
		"esbuild-plugin-tailwindcss": "npm:esbuild-plugin-tailwindcss@^2.2.0",
		"htmx-ext-debug": "npm:htmx-ext-debug@^2.0.2",
		"htmx-ext-ws": "npm:htmx-ext-ws@^2.0.4",
		"htmx.org": "npm:htmx.org@^2.0.10",
		"is-ci": "npm:is-ci@^4.1.0",
		"semver": "npm:semver@^7.8.5",
		"swagger-ui-dist": "npm:swagger-ui-dist@^5.32.8",
		"tailwindcss": "npm:tailwindcss@^4.3.2",
		"tree-kill": "npm:tree-kill@^1.2.2"
	},
	"exports": {},
	"exclude": [
		"dist",
		"client/src/*tailwind*"
	],
	"fmt": {
		"indentWidth": 1,
		"useTabs": true
	},
	"lint": {
		"rules": {
			"include": [
				"default-param-last",
				"explicit-function-return-type",
				"no-import-prefix",
				"no-unused-vars",
				"no-debugger",
				"ban-unused-ignore",
				"camelcase",
				"ban-untagged-ignore",
				"ban-untagged-todo",
				"eqeqeq",
				"explicit-module-boundary-types",
				"guard-for-in",
				"no-inferrable-types",
				"no-non-null-asserted-optional-chain",
				"no-slow-types",
				"no-sparse-arrays",
				"no-useless-rename",
				"verbatim-module-syntax"
			]
		}
	},
	"compilerOptions": {
		"lib": [
			"esnext",
			"dom",
			"dom.iterable",
			"dom.asynciterable",
			"deno.ns"
		]
	},
	"allowScripts": [
		"npm:@scarf/scarf@1.4.0",
		"npm:esbuild@0.25.12",
		"npm:esbuild@0.27.3"
	]
}
