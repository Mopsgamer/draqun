{
	"name": "@m234/draqun",
	"version": "0.0.0",
	"nodeModulesDir": "auto",
    "minimumDependencyAge": {
        "exclude": ["@m234/logger"],
        "age": "P2D"
    },
	"tasks": {
		"init": "deno run -A scripts/init.ts",
		"dev": "deno run -A scripts/dev.ts",
		"prod": "deno run -A scripts/prod.ts",
		"prepare": "deno lint & deno fmt & deno check",
		"compile:client": "deno run -A scripts/compile-client.ts",
		"compile:server": "deno run -A scripts/compile-server.ts",
		"compile:server:cross": "deno run -A scripts/compile-server-cross.ts",
		"release": "deno run -A scripts/release.ts"
	},
	"imports": {
		"@deno/esbuild-plugin": "jsr:@deno/esbuild-plugin@1.x",
		"@m234/logger": "jsr:@m234/logger@3.x",
		"@octokit/rest": "npm:@octokit/rest@22.x",
		"@shoelace-style/shoelace": "npm:@shoelace-style/shoelace@2.x",
		"@std/fmt": "jsr:@std/fmt@1.x",
		"@std/fs": "jsr:@std/fs@1.x",
		"@std/path": "jsr:@std/path@1.x",
		"@tailwindcss/postcss": "npm:@tailwindcss/postcss@4.x",
		"@types/semver": "npm:@types/semver@7.x",
		"@types/swagger-ui-dist": "npm:@types/swagger-ui-dist@3.x",
		"dotenv": "npm:dotenv@17.x",
		"esbuild": "npm:esbuild@^0.28.0",
		"esbuild-plugin-tailwindcss": "npm:esbuild-plugin-tailwindcss@2.x",
		"htmx-ext-debug": "npm:htmx-ext-debug@2.x",
		"htmx-ext-ws": "npm:htmx-ext-ws@2.x",
		"htmx.org": "npm:htmx.org@2.x",
		"is-ci": "npm:is-ci@4.x",
		"semver": "npm:semver@7.x",
		"swagger-ui-dist": "npm:swagger-ui-dist@5.x",
		"tailwindcss": "npm:tailwindcss@4.x",
		"tree-kill": "npm:tree-kill@1.x"
	},
	"exports": {},
	"exclude": [
		"dist/static",
		"client/src/*tailwind*"
	],
	"fmt": {
		"indentWidth": 1,
		"useTabs": true
	},
	"lint": {
		"rules": {
			"include": [
				"default-param-last",
				"explicit-function-return-type",
				"no-import-prefix",
				"no-useless-rename"
			]
		}
	},
	"compilerOptions": {
		"lib": [
			"esnext",
			"dom",
			"dom.iterable",
			"dom.asynciterable",
			"deno.ns"
		]
	},
	"allowScripts": [
		"npm:@scarf/scarf@1.4.0",
		"npm:esbuild@0.25.12",
		"npm:esbuild@0.27.3"
	]
}
